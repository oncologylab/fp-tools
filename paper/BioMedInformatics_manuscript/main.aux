\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Demonstration bulk-matched benchmark on ENCODE ATAC-seq (chromosome~4), ranking accessible regions by raw accessibility versus a motif-aware PWM score and labeling by matched ChIP-seq overlap. AUROC values are point estimates with 200- resample bootstrap 95\% CIs; motif-aware scoring significantly beats the baseline for every factor and cell type.}}{7}{table.caption.2}\protected@file@percent }
\newlabel{tab:k562}{{2}{7}{Demonstration bulk-matched benchmark on ENCODE ATAC-seq (chromosome~4), ranking accessible regions by raw accessibility versus a motif-aware PWM score and labeling by matched ChIP-seq overlap. AUROC values are point estimates with 200- resample bootstrap 95\% CIs; motif-aware scoring significantly beats the baseline for every factor and cell type}{table.caption.2}{}}
\newlabel{tab:k562@cref}{{[table][2][]2}{[1][7][]7}}
