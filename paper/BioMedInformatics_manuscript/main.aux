\citation{chrombpnet2024}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Predictor comparison for K562 CTCF (chromosome~4). A footprint-occupancy score is informative only at Tn5 cut-site resolution (green, AUROC $0.68$); the same score on smoothed coverage is inverted and uninformative (red, $0.24$). Raw accessibility (grey) is near chance and the CTCF motif (blue) is the single strongest predictor.}}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:footprint}{{2}{8}{Predictor comparison for K562 CTCF (chromosome~4). A footprint-occupancy score is informative only at Tn5 cut-site resolution (green, AUROC $0.68$); the same score on smoothed coverage is inverted and uninformative (red, $0.24$). Raw accessibility (grey) is near chance and the CTCF motif (blue) is the single strongest predictor}{figure.caption.4}{}}
